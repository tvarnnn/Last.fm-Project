library(ggplot2)
library(dplyr)

# Read CSV
tracks <- read.csv("data/all_tracks.csv", stringsAsFactors = FALSE)

# Count plays per artist
artists_counts <- tracks %>%
  group_by(`artist..text`) %>%
  summarise(total_tracks = n()) %>%
  arrange(desc(total_tracks))

# Top 10 artists
top_artists <- head(artists_counts, 5)

# Misc category for all others
misc_count <- sum(artists_counts$total_tracks) - sum(top_artists$total_tracks)
top_artists <- rbind(top_artists, data.frame(`artist..text` = "Misc", total_tracks = misc_count))

# Add percentage for legend
top_artists <- top_artists %>%
  mutate(legend_label = paste0(`artist..text`, " (", round(100 * total_tracks / sum(total_tracks), 1), "%)"))

# Pie chart with percentages in legend
p <- ggplot(top_artists, aes(x = "", y = total_tracks, fill = legend_label)) +
  geom_bar(stat = "identity", width = 1) + 
  coord_polar("y", start = 0) +
  labs(title = "Top 5 Artists by Plays") +
  theme_void() +
  theme(legend.title = element_blank())

# Print plot
print(p)
