library(httr)
library(jsonlite)
library(dplyr)
library(ggplot2)

user <- "Not_Herro"
api_key <- "9a79c08e6161f504681828923a16f3c0"
csv_file <- "data/all_tracks.csv"

limit <- 1000
page <- 1
total_pages <- 1

repeat {
  url <- paste0(
    "http://ws.audioscrobbler.com/2.0/?method=user.getrecenttracks&user=",
    user, "&api_key=", api_key, "&format=json&limit=", limit, "&page=", page
  )
  
  response <- GET(url)
  content <- fromJSON(content(response, "text"), flatten = TRUE)
  tracks <- content$recenttracks$track
  
  # Flatten any list-columns that are still lists
  tracks_df <- as.data.frame(tracks, stringsAsFactors = FALSE)
  
  # Convert list-columns to character
  for (col in names(tracks_df)) {
    if (is.list(tracks_df[[col]])) {
      tracks_df[[col]] <- sapply(tracks_df[[col]], function(x) {
        if (length(x) == 0) return(NA)
        paste(x, collapse = "; ")  # join list elements into one string
      })
    }
  }
  
  # Save/append to CSV | makes sure API is only called one time
  write.table(tracks_df, csv_file, sep = ",", row.names = FALSE,
              col.names = (page == 1), append = (page > 1))
  
  # Update total pages
  total_pages <- as.numeric(content$recenttracks[["@attr"]]$totalPages)
  cat("Fetched page", page, "of", total_pages, "\n")
  
  if (page >= total_pages) break
  page <- page + 1
}

# Optional: read CSV to view all data
all_tracks <- read.csv(csv_file, stringsAsFactors = FALSE)
View(all_tracks)

